{
	"servers": [
		{
			"port": 8080,
			"fileBrowser": {
				"enabled": true,
				"route": "/files",
				"root": "./sololv"
			},
			"files": [
				{
					"route": "/",
					"path": "sololv/apis.netmarble.com",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				},
				{
					"route": "/",
					"path": "sololv/netmarbleslog.netmarble.com",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				},
				{
					"route": "/",
					"path": "sololv/nmss.gcdn.netmarble.com",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				},
				{
					"route": "/",
					"path": "sololv/sololvcs.gcdn.netmarble.com",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				},
				{
					"route": "/",
					"path": "asset:index.html",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				},
				{
					"route": "/404.html",
					"path": "asset:404.html",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				},
				{
					"route": "/base.css",
					"path": "asset:base.css",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				},
				{
					"route": "/filebrowser.css",
					"path": "asset:filebrowser.css",
					"info": {
						"statusCode": 0,
						"headers": {}
					}
				}
			]
		}
	]
}
